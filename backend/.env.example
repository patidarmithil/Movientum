# =============================================================================
# MOVIENTUM — .env.example  (safe to commit — no real secrets)
# Copy to .env and fill values before running.
# =============================================================================

# --- TMDB ---
TMDB_API_KEY=your_tmdb_api_key
TMDB_READ_ACCESS_TOKEN=your_tmdb_read_access_token
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p

# --- Supabase PostgreSQL ---
DB_PASSWORD=your_supabase_db_password

# Direct connection (Alembic migrations — port 6543 is transaction pooler)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

# Session pooler (FastAPI runtime — port 5432)
DATABASE_POOL_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# Async SQLAlchemy URL (asyncpg driver)
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# --- Redis (Upstash or any Redis provider) ---
REDIS_URL=redis://default:YOUR_REDIS_PASSWORD@YOUR_REDIS_HOST:6379

# --- JWT ---
JWT_SECRET_KEY=generate_64_char_hex_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Celery ---
CELERY_BROKER_URL=redis://default:YOUR_REDIS_PASSWORD@YOUR_REDIS_HOST:6379
CELERY_RESULT_BACKEND=redis://default:YOUR_REDIS_PASSWORD@YOUR_REDIS_HOST:6379
